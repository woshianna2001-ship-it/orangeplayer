<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <ScrollView
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#E6222222"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OCR 翻译设置"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- 说明 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="识别视频画面中的硬字幕并翻译"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="16dp" />

            <!-- 语言包管理入口 -->
            <LinearLayout
                android:id="@+id/btn_manage_language_pack"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/btn_subtitle_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="管理语言包"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_language_pack_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已安装 0 个"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="#888888" />
            </LinearLayout>

            <!-- 设置扫描区域入口 -->
            <LinearLayout
                android:id="@+id/btn_set_scan_region"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/btn_subtitle_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="设置扫描区域"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_scan_region_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="底部 20%"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="#888888" />
            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#444444"
                android:layout_marginBottom="16dp" />

            <!-- 源语言 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字幕语言（源语言）"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_source_lang"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/spinner_bg"
                android:layout_marginBottom="16dp" />

            <!-- 目标语言 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="翻译语言（目标语言）"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_target_lang"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/spinner_bg"
                android:layout_marginBottom="16dp" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#444444"
                android:layout_marginBottom="16dp" />

            <!-- 按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_cancel"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="取消"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/btn_subtitle_bg"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_start_ocr"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="开始识别"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/btn_primary_bg" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
