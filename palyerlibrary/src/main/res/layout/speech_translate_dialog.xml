<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true">

    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#E6222222"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <!-- 标题 - 改为"语音识别与翻译" -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="语音识别与翻译"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- 提示 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="识别视频中的语音并显示为字幕，需要录音权限"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="16dp" />

            <!-- 管理语言包按钮 -->
            <LinearLayout
                android:id="@+id/btn_manage_language_pack"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/btn_subtitle_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="管理语言包"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_installed_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已安装 0 个"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textColor="#888888"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 源语言 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="识别语言"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_speech_source"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/spinner_bg"
                android:layout_marginBottom="8dp" />

            <!-- 无语言提示 -->
            <TextView
                android:id="@+id/tv_no_language_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请先下载至少一个语言包"
                android:textColor="#FF9800"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#444444"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <!-- 翻译开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="启用翻译"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <Switch
                    android:id="@+id/switch_translate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- 翻译说明 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="关闭后只显示识别的原文，不进行翻译"
                android:textColor="#888888"
                android:textSize="11sp"
                android:layout_marginBottom="16dp" />

            <!-- 目标语言 -->
            <TextView
                android:id="@+id/tv_target_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="翻译为"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_speech_target"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/spinner_bg"
                android:layout_marginBottom="24dp" />

            <!-- 按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_cancel_speech"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="取消"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:background="@drawable/btn_cancel_bg"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_start_speech"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="开始识别"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:background="@drawable/btn_primary_bg"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
