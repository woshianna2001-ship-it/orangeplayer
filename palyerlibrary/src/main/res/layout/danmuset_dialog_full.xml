<?xml version="1.0" encoding="UTF-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 内容面板 - 右侧居中 -->
    <LinearLayout
        android:id="@+id/content_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="32dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/shik"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:background="@drawable/setup_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <ScrollView
                android:id="@+id/gd1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="320dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/ai_setting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 弹幕设置标题 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center"
                        android:text="弹幕设置"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- 弹幕文字大小 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="文字大小"
                            android:textColor="#E6FFFFFF"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/ai_size"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50%"
                            android:textColor="#B3FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/ai_sizebar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp"
                        android:background="@null"
                        android:max="100"
                        android:maxHeight="4dp"
                        android:minHeight="4dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progress="50"
                        android:progressDrawable="@drawable/seekbar_progress"
                        android:thumb="@drawable/dkplayer_seekbar_thumb"
                        android:thumbOffset="0dp" />

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#1AFFFFFF" />

                    <!-- 弹幕速度 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="播放速度"
                            android:textColor="#E6FFFFFF"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/ai_speed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50%"
                            android:textColor="#B3FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/ai_speedbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp"
                        android:background="@null"
                        android:max="100"
                        android:maxHeight="4dp"
                        android:minHeight="4dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progress="50"
                        android:progressDrawable="@drawable/seekbar_progress"
                        android:thumb="@drawable/dkplayer_seekbar_thumb"
                        android:thumbOffset="0dp" />

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#1AFFFFFF" />

                    <!-- 弹幕透明度 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="透明度"
                            android:textColor="#E6FFFFFF"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/ai_alpha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100%"
                            android:textColor="#B3FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/ai_alphabar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@null"
                        android:max="100"
                        android:maxHeight="4dp"
                        android:minHeight="4dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progress="100"
                        android:progressDrawable="@drawable/seekbar_progress"
                        android:thumb="@drawable/dkplayer_seekbar_thumb"
                        android:thumbOffset="0dp" />

                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
