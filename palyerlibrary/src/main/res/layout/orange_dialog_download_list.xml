<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/orange_shape_dialog_bg"
        android:orientation="vertical"
        android:padding="16dp">
        
        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="12dp">
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_download"
                android:tint="#FF9800" />
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="下载管理"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
            
            <ImageView
                android:id="@+id/btn_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_close"
                android:contentDescription="关闭"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#AAAAAA" />
        </LinearLayout>
        
        <!-- 操作按钮栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">
            
            <TextView
                android:id="@+id/tv_task_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="共 0 个任务"
                android:textColor="#99FFFFFF"
                android:textSize="12sp" />
            
            <TextView
                android:id="@+id/btn_start_all"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="全部开始"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless" />
            
            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:background="#33FFFFFF"
                android:layout_marginHorizontal="6dp" />
            
            <TextView
                android:id="@+id/btn_pause_all"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="全部暂停"
                android:textColor="#FF9800"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless" />
            
            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:background="#33FFFFFF"
                android:layout_marginHorizontal="6dp" />
            
            <TextView
                android:id="@+id/btn_clear"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="全部删除"
                android:textColor="#F44336"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
        
        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF" />
        
        <!-- 任务列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:maxHeight="380dp"
            android:layout_marginTop="8dp"
            android:scrollbars="vertical"
            android:overScrollMode="never"
            tools:listitem="@layout/orange_item_download_task" />
        
        <!-- 空状态 -->
        <LinearLayout
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            tools:visibility="visible">
            
            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_download"
                android:tint="#333333"
                android:layout_marginBottom="16dp" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="暂无下载任务"
                android:textSize="15sp"
                android:textColor="#666666" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击视频播放页的下载按钮开始下载"
                android:textSize="12sp"
                android:textColor="#444444"
                android:layout_marginTop="6dp" />
        </LinearLayout>
        
    </LinearLayout>
    
</FrameLayout>
