<?xml version="1.0" encoding="UTF-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/round"
    android:padding="12dp">
    
    <!-- 输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/danmu_input_bg"
        android:paddingEnd="4dp">
        
        <!-- 输入框 -->
        <EditText
            android:id="@+id/et_danmu"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="发个友善的弹幕吧~"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:textSize="14sp"
            android:maxLines="1"
            android:maxLength="32"
            android:background="@null"
            android:textColor="#FFFFFF"
            android:textColorHint="#FF888888"/>
            
        <!-- 发送按钮 -->
        <Button
            android:id="@+id/btn_send"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="60dp"
            android:text="发送"
            android:textSize="14sp"
            android:textColor="#FF94D3FF"
            android:background="#00000000"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center"/>
    </LinearLayout>
    
    <!-- 字数统计 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">
        
        <TextView
            android:id="@+id/tv_danmu_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/32"
            android:textSize="12sp"
            android:textColor="#FF888888"
            android:layout_gravity="end"
            android:paddingEnd="4dp"/>
    </LinearLayout>
    
    <!-- 颜色选择区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:paddingBottom="4dp">
        
        <!-- 颜色标签 -->
        <TextView
            android:id="@+id/tv_color_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="弹幕色："
            android:textColor="#FF888888"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"/>
            
        <!-- 颜色选择器 -->
        <GridView
            android:id="@+id/grid_color"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:numColumns="7"
            android:horizontalSpacing="6dp"
            android:verticalSpacing="6dp"
            android:stretchMode="columnWidth"
            android:gravity="center"/>
        
        <!-- 颜色预览 -->
        <TextView
            android:id="@+id/tv_preview"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/color_circle_bg"
            android:layout_marginEnd="4dp"/>
    </LinearLayout>
</LinearLayout>
