<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <ImageView
        android:id="@+id/stop_fullscreen"
        android:layout_width="@dimen/orange_controller_height"
        android:layout_height="@dimen/orange_controller_height"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:padding="@dimen/orange_controller_icon_padding"
        android:src="@drawable/orange_ic_action_arrow_back"
        android:visibility="visible" />

    <ImageView
        android:id="@+id/error_settings_btn"
        android:layout_width="@dimen/orange_controller_height"
        android:layout_height="@dimen/orange_controller_height"
        android:layout_gravity="top|end"
        android:layout_marginTop="10dp"
        android:layout_marginRight="20dp"
        android:padding="@dimen/orange_controller_icon_padding"
        android:src="@drawable/ic_settings_player"
        android:contentDescription="@string/orange_settings" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/status_btn"
            android:layout_width="@dimen/orange_play_btn_size"
            android:layout_height="@dimen/orange_play_btn_size"
            android:layout_gravity="center"
            android:layout_marginBottom="15dp"
            android:background="@drawable/orange_shape_play_bg"
            android:padding="@dimen/orange_controller_icon_padding"
            android:src="@drawable/orange_ic_action_replay" />

        <TextView
            android:id="@+id/message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/orange_error_message"
            android:textColor="#ffe6e6e6" />

    </LinearLayout>
</FrameLayout>
