<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <ScrollView
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#E6222222"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字幕设置"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- 字幕开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="显示字幕"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <Switch
                    android:id="@+id/subtitle_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- 字幕状态 -->
            <TextView
                android:id="@+id/subtitle_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未加载字幕"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="16dp" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#444444"
                android:layout_marginBottom="16dp" />

            <!-- 加载字幕按钮 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="加载字幕"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_load_local"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="从本地加载"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_subtitle_bg"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_load_url"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="从网络加载"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_subtitle_bg" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#444444"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- OCR 翻译字幕 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OCR 翻译字幕"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/ocr_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="识别视频画面中的硬字幕并翻译"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_ocr_translate"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="开启 OCR 翻译"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_subtitle_bg" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#444444"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- 语音识别与翻译 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="语音识别与翻译"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/speech_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="识别视频音频并翻译为字幕"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_speech_translate"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="开启语音识别"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/btn_subtitle_bg" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#444444"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- 字幕大小 -->
            <TextView
                android:id="@+id/subtitle_size_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="字幕大小: 24sp"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <SeekBar
                android:id="@+id/subtitle_size_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
