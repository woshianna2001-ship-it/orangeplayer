<?xml version="1.0" encoding="UTF-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 内容面板 - 右侧滑入 -->
    <LinearLayout
        android:id="@+id/content_layout"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@drawable/setup_panel_bg"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:clickable="true"
        android:focusable="true">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/main_set"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ========== 快捷功能 ========== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="快捷功能"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <!-- 第一行: 画面比例/长按倍速/定时关闭 -->
                <LinearLayout
                    android:id="@+id/set_line1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <LinearLayout
                        android:id="@+id/line1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/setup_icon_bg">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@mipmap/huamian"
                                android:clickable="false"
                                android:focusable="false" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="画面比例"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/line2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/setup_icon_bg">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@mipmap/longspeeds"
                                android:clickable="false"
                                android:focusable="false" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="长按倍速"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/line3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/setup_icon_bg">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@mipmap/times"
                                android:clickable="false"
                                android:focusable="false" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="定时关闭"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 第二行: 跳过片头/跳过片尾/小窗播放 -->
                <LinearLayout
                    android:id="@+id/set_line2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="4dp">

                    <LinearLayout
                        android:id="@+id/line4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/setup_icon_bg">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@mipmap/playtop"
                                android:clickable="false"
                                android:focusable="false" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="跳过片头"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/line5"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/setup_icon_bg">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@mipmap/playbottom"
                                android:clickable="false"
                                android:focusable="false" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="跳过片尾"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/line6"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/setup_icon_bg">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@mipmap/window"
                                android:clickable="false"
                                android:focusable="false" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="小窗播放"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 第四行: 下载/进度条 -->
                <LinearLayout
                    android:id="@+id/set_line4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="4dp">

                    <LinearLayout
                        android:id="@+id/line10"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/setup_icon_bg">
                            <ImageView
                                android:id="@+id/tx1"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@mipmap/ax"
                                android:clickable="false"
                                android:focusable="false" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/wb1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="下载视频"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/line7"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/setup_icon_bg">
                            <ImageView
                                android:id="@+id/kgImage"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@mipmap/kg1"
                                android:clickable="false"
                                android:focusable="false" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/wb2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="进度条"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <!-- 截图按钮 -->
                    <LinearLayout
                        android:id="@+id/line_screenshot"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/setup_icon_bg">
                            <ImageView
                                android:id="@+id/screenshot_icon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_screenshot"
                                android:clickable="false"
                                android:focusable="false" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="截图"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 分隔线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="#1AFFFFFF" />

                <!-- ========== 播放核心 ========== -->
                <LinearLayout
                    android:id="@+id/set_line3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/xdbj1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:id="@+id/xxbj1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/setup_card_bg"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/wb4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="播放核心"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:id="@+id/xxbj2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="12dp"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/alihx"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="4dp"
                                    android:text="Ali"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <TextView
                                    android:id="@+id/exohx"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="4dp"
                                    android:layout_marginEnd="4dp"
                                    android:text="Exo"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <TextView
                                    android:id="@+id/ijkhx"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="4dp"
                                    android:layout_marginEnd="4dp"
                                    android:text="Ijk"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <TextView
                                    android:id="@+id/systemhx"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="4dp"
                                    android:text="系统"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- 解码方式 -->
                        <LinearLayout
                            android:id="@+id/decode_mode_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_below="@id/xxbj1"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/setup_card_bg"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="解码方式"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="12dp"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/decode_hardware"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="4dp"
                                    android:text="硬件解码"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <TextView
                                    android:id="@+id/decode_software"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="4dp"
                                    android:text="软件解码"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- 播放方式 -->
                        <LinearLayout
                            android:id="@+id/xxbj3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_below="@id/decode_mode_layout"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/setup_card_bg"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/wb5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="播放方式"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:id="@+id/xxbj5"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="12dp"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/sxbf"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="4dp"
                                    android:text="顺序播放"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <TextView
                                    android:id="@+id/djxh"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="4dp"
                                    android:layout_marginEnd="4dp"
                                    android:text="单集循环"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <TextView
                                    android:id="@+id/bwzt"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="4dp"
                                    android:text="播完暂停"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />
                            </LinearLayout>
                        </LinearLayout>
                        
                        <!-- 自动旋转 -->
                        <LinearLayout
                            android:id="@+id/auto_rotate_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_below="@id/xxbj3"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/setup_card_bg"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="全屏自动旋转"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="12dp"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/auto_rotate_on"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="4dp"
                                    android:text="开启"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <TextView
                                    android:id="@+id/auto_rotate_off"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="4dp"
                                    android:text="关闭"
                                    android:textSize="11sp"
                                    android:textColor="#E6FFFFFF"
                                    android:gravity="center"
                                    android:background="@drawable/setup_option_bg"
                                    android:clickable="true"
                                    android:focusable="true" />
                            </LinearLayout>
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>

                <!-- 分隔线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="#1AFFFFFF" />

                <!-- ========== 音量控制 ========== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/setup_card_bg"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="音量"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/volumeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100%"
                            android:textSize="12sp"
                            android:textColor="#B3FFFFFF" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/volumeSeek_bar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@null"
                        android:max="1000"
                        android:maxHeight="4dp"
                        android:minHeight="4dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progressDrawable="@drawable/seekbar_progress"
                        android:thumb="@drawable/dkplayer_seekbar_thumb"
                        android:thumbOffset="0dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</FrameLayout>
