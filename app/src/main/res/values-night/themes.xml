<resources xmlns:tools="http://schemas.android.com/tools">
	<!-- Base application theme. -->
	<style name="Base.Theme.橘子播放器" parent="Theme.Material3.DayNight.NoActionBar">
		<!-- 主题色改为橙色 -->
		<item name="colorPrimary">#FF6B35</item>
		<item name="colorPrimaryContainer">#FF6B35</item>
		<item name="colorOnPrimaryContainer">#FFFFFF</item>
		<item name="colorSecondary">#FF6B35</item>
		<item name="colorAccent">#FF6B35</item>
		<!-- 按钮颜色 -->
		<item name="materialButtonStyle">@style/OrangeButton</item>
