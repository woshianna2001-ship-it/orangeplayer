<resources xmlns:tools="http://schemas.android.com/tools">
	<!-- Base application theme. -->
	<style name="Base.Theme.橘子播放器" parent="Theme.Material3.DayNight.NoActionBar">
		<!-- Customize your light theme here. -->
		<!-- 主题色改为橙色 -->
		<item name="colorPrimary">#FF6B35</item>
		<item name="colorPrimaryContainer">#FF6B35</item>
		<item name="colorOnPrimaryContainer">#FFFFFF</item>
		<item name="colorSecondary">#FF6B35</item>
		<item name="colorAccent">#FF6B35</item>
		<!-- 按钮颜色 -->
		<item name="materialButtonStyle">@style/OrangeButton</item>
		<!-- 状态栏设置 -->
		<item name="android:statusBarColor">@android:color/black</item>
		<item name="android:windowLightStatusBar">false</item>
	</style>
	
	<!-- 橙色按钮样式 -->
	<style name="OrangeButton" parent="Widget.Material3.Button">
		<item name="backgroundTint">#444444</item>
		<item name="android:textColor">#FFFFFF</item>
	</style>
	
	<style name="Theme.橘子播放器" parent="Base.Theme.橘子播放器"/>
</resources>